PORT=5000
MONGODB_URI=mongodb://localhost:27017/ai-workspace
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Code Execution (Piston) ────────────────────────────────────────────────────
# The public Piston API (emkc.org) is now whitelist-only as of 2/15/2026.
# The server automatically falls back to a Node.js vm sandbox mock executor
# for JavaScript when Piston is unavailable (Python requires self-hosting).
#
# To enable full execution for both JS and Python, self-host Piston via Docker:
#
#   docker run -d --name piston \
#     -p 2000:2000 \
#     -v piston_data:/piston \
#     ghcr.io/engineer-man/piston:latest
#
#   # Then install runtimes:
#   curl -s http://localhost:2000/api/v2/piston/runtimes   # check available
#   # Runtimes auto-install on first execution request
#
# Then uncomment and set:
# PISTON_API_URL=http://localhost:2000/api/v2/piston
